+    @staticmethod
+    def _bounds_are_feasible(
+        lower_bounds: pd.Series,
+        max_weight: float,
+        tol: float = 1e-9,
+    ) -> bool:
+        if lower_bounds.empty:
+            return False
+        if np.any(lower_bounds.to_numpy(dtype=float) > (max_weight + tol)):
+            return False
+        lower_sum = float(lower_bounds.sum())
