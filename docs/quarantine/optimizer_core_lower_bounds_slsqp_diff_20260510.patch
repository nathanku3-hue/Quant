+        lower_bounds: pd.Series,
+        tol: float = 1e-9,
+    ) -> pd.Series:
+        """Build a fallback that respects lower bounds when feasible."""
+        if len(index) == 0:
+            return pd.Series(dtype=float)
+        if lower_bounds.empty:
+            return pd.Series(1.0 / len(index), index=index, dtype=float)
+        if not PortfolioOptimizer._bounds_are_feasible(lower_bounds, max_weight, tol=tol):
+            return pd.Series(1.0 / len(index), index=index, dtype=float)
+
+        weights = lower_bounds.reindex(index).fillna(0.0).astype(float).clip(lower=0.0)
+        remaining = 1.0 - float(weights.sum())
+        while remaining > tol:
+            room = (float(max_weight) - weights).clip(lower=0.0)
+            eligible = room[room > tol]
+            if eligible.empty:
+                break
+            add_each = remaining / len(eligible)
+            additions = np.minimum(eligible.to_numpy(dtype=float), add_each)
+            weights.loc[eligible.index] = weights.loc[eligible.index] + additions
+            new_remaining = 1.0 - float(weights.sum())
+            if new_remaining >= remaining - tol:
+                break
+            remaining = new_remaining
+
+        total = float(weights.sum())
+        if total > 0:
+            weights = weights / total
+        return weights
